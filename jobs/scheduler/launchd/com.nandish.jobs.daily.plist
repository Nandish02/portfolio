<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
        "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.nandish.jobs.daily</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/nandish.chokshi/Downloads/portfolio/jobs/scheduler/run_full.sh</string>
    </array>

    <!-- 6:00 AM local time, every day -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/nandish.chokshi/Downloads/portfolio/jobs/data/logs/daily.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/nandish.chokshi/Downloads/portfolio/jobs/data/logs/daily.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
