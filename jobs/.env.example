# =========================================================================
# AI SCORER BACKEND
# =========================================================================
# 'auto' (recommended) picks the best provider based on which keys are set,
# in this order:  ANTHROPIC > OPENAI > GEMINI > BEDROCK > GITHUB_MODELS > none.
# Explicit override:  claude_api | openai_api | gemini_api | github_models | bedrock | none
JOB_SCORER=auto

# --- Anthropic Claude (best output quality) ---------------------------------
# Get key:  https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_BASE=https://api.anthropic.com

# --- OpenAI / ChatGPT --------------------------------------------------------
# Get key:  https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE=https://api.openai.com/v1

# --- Google Gemini (cheapest, generous free tier) ----------------------------
# Get key:  https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE=https://generativelanguage.googleapis.com/v1beta

# --- GitHub Models (free with `gh auth login`) -------------------------------
GITHUB_TOKEN=
GITHUB_MODELS_BASE=https://models.github.ai/inference
GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# --- AWS Bedrock (Phase 1 — switch to this once your $200 AWS credit is live)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-sonnet-4-6

# =========================================================================
# PIPELINE KNOBS
# =========================================================================
MAX_JOBS_PER_RUN=5000
SCORE_TOP_N=300
SCORER_CONCURRENCY=3
HTTP_TIMEOUT_S=30
HTTP_CONCURRENCY=20
DAYS_FRESH=21
# Skip AI re-scoring of jobs scored within the last N days (set 0 to always re-score).
RESCORE_AFTER_DAYS=14
LOG_LEVEL=INFO

# =========================================================================
# GOOGLE SHEETS EXPORT (optional)
# =========================================================================
# 1. console.cloud.google.com  ->  new project  ->  enable Sheets API + Drive API
# 2. APIs & Services -> Credentials -> create Service Account -> create JSON key
# 3. Save the JSON path here:
GOOGLE_SHEETS_SA_JSON=
# Optional: existing Sheet ID (after /d/ in its URL).  Leave blank to auto-create.
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_TITLE=Internship Hunt 2027
# Email to share the auto-created Sheet with (you):
GOOGLE_SHEETS_SHARE_WITH=

# =========================================================================
# NOTIFICATIONS (optional)
# =========================================================================
DISCORD_WEBHOOK_URL=
